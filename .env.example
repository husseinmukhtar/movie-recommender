# Copy to .env and fill in your values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

APP_NAME="Movie Recommender API"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# Database (SQLite for dev, switch to PostgreSQL for prod)
DATABASE_URL=sqlite:///./recommender.db
# DATABASE_URL=postgresql://recommender:password@localhost:5432/recommender_db

# Redis
REDIS_URL=redis://localhost:6379/0
MODEL_CACHE_TTL_SECONDS=1800
FEATURE_CACHE_TTL_SECONDS=14400

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_USER_EVENTS=user-events

# Auth — CHANGE THIS IN PRODUCTION
SECRET_KEY=dev_secret_key_replace_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ML hyperparameters
ALS_FACTORS=128
ALS_REGULARIZATION=0.01
ALS_ITERATIONS=30
TWO_TOWER_EMBEDDING_DIM=64
TWO_TOWER_EPOCHS=20
RANKER_N_ESTIMATORS=500
RECOMMENDATION_POOL_SIZE=500
MAX_RECOMMENDATIONS=50

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=movie-recommender

# External APIs
TMDB_API_KEY=your_tmdb_key_here
